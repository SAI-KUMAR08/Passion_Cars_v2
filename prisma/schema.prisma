generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  email     String?
  password  String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Otp {
  id        Int      @id @default(autoincrement())
  phone     String
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Car {
  id            Int      @id @default(autoincrement())
  displayId     Int      @unique
  name          String
  brand         String
  year          Int
  transmission  String
  fuel          String
  color         String
  kilometers    Int
  price         Int
  originalPrice Int?
  image         String
  images        String[]
  stockId       String
  onSale        Boolean  @default(true)
  sold          Boolean  @default(false)
  description   String?
  createdAt     DateTime @default(now())
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}
